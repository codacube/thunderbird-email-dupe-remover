{
  "manifest_version": 2,
  "name": "Duplicate Cleanup",
  "version": "2.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png"
  },
  "description": "Clean up your folders by scanning for duplicates and removing them",
  "permissions": [
    "menus",
    "messagesRead",
    "messagesMove",
    "messagesDelete",
    "accountsRead",
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "duplicate-cleanup@codacube.com",
      "strict_min_version": "102.0"
    }
  }
}
